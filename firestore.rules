rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // User documents — only accessible by the owner
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Resumes subcollection
      match /resumes/{resumeId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Cover letters subcollection
      match /coverLetters/{letterId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // ATS reports subcollection
      match /atsReports/{reportId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
